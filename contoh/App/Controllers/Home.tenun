// Controller Home.

fungsi home_index(): teks {
    kembali jala_tampil_tata("Layout", "Home", peta{
        "judul": "Beranda",
        "pesan": "Halo dari Jala! Edit App/Controllers/Home.tenun dan Views/Home.batik."
    });
}

fungsi home_about(): teks {
    kembali jala_tampil_tata("Layout", "About", peta{ "judul": "Tentang" });
}
